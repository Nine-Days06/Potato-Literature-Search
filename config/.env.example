# ── API 密钥配置 ──────────────────────────────────
# 复制此文件为 .env，填入你的真实密钥后保存
# .env 已在 .gitignore 中，不会被提交到仓库

# NCBI E-utilities API Key（免费申请：https://www.ncbi.nlm.nih.gov/account/）
# 留空也可运行，但速率限制为 3 次/秒
NCBI_API_KEY=

# DeepSeek API Key（https://platform.deepseek.com/）
DEEPSEEK_API_KEY=

# 智谱AI API Key（https://open.bigmodel.cn/）
ZHIPU_API_KEY=

# 其他 OpenAI 兼容 API Key（如 OpenAI、SiliconFlow 等）
OPENAI_API_KEY=

# NCBI 联系邮箱（NCBI 强制要求，否则 API 可能被限）
NCBI_EMAIL=
